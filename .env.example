# ── Syner Cortex environment ─────────────────────────────────────────────
# Copy to `.env` and fill in. Loaded via python-dotenv.

# Environment: "development" (defaults, dev fallbacks) or "production"
ENV=development

# Database — SQLite for local dev; Postgres for real-client / production.
#   Dev (default):   sqlite:///./syner_cortex.db
#   Postgres:        postgresql+psycopg2://syner:CHANGE_ME@127.0.0.1:5432/syner_cortex
DATABASE_URL=sqlite:///./syner_cortex.db

# JWT signing secret. REQUIRED in production (app refuses to start without it).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
ACCESS_TOKEN_EXPIRE_MINUTES=120

# CORS — comma-separated allowed origins (the frontend URL(s)).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Password policy
MIN_PASSWORD_LENGTH=8

# Initial Syner crew admin (used by app/scripts/bootstrap_admin.py — to be added
# during the Postgres cutover, replacing the dev auto-seeded admin).
SYNER_ADMIN_EMAIL=
SYNER_ADMIN_PASSWORD=
